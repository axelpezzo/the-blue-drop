{% set has_date = node.field_event_date.value is not empty %}
{% set has_date_end = node.field_event_date_end.value is not empty %}
{% set has_location = node.field_event_localtion.value is not empty %}
{% set has_image = content.field_event_image|render|striptags|trim is not empty %}
{% set has_type = node.field_event_type.entity is not empty %}

<article class="group flex overflow-hidden bg-card transition-all duration-300 hover:-translate-y-px">
  {# ── Immagine — sinistra ───────────────────────────────────────── #}
  <a href="{{ url }}" class="relative w-48 shrink-0 overflow-hidden sm:w-56 md:w-64 lg:w-72" tabindex="-1" aria-hidden="true">
    {% if has_image %}
      <div class="image-cover-container image-cover-container--slow">
        {{ content.field_event_image }}
      </div>
    {% else %}
      <div class="absolute inset-0 bg-gradient-to-br from-primary via-primary to-accent"></div>
      <div class="absolute inset-0 bg-primary/70 transition-opacity duration-300 group-hover:bg-primary/60"></div>
      <div class="absolute -right-6 -bottom-6 h-32 w-32 rounded-full bg-white/5"></div>
      <div class="absolute -top-3 -left-3 h-16 w-16 rounded-full bg-white/5"></div>
      <div class="absolute inset-0 flex items-center justify-center">
        <svg
          viewBox="0 0 80 80"
          class="h-14 w-14 text-white/20"
          fill="none"
          stroke="currentColor"
          stroke-linecap="round"
          stroke-linejoin="round"
          aria-hidden="true"
        >
          <rect x="10" y="14" width="60" height="56" rx="6" stroke-width="2.5" />
          <line x1="26" y1="6" x2="26" y2="22" stroke-width="2.5" />
          <line x1="54" y1="6" x2="54" y2="22" stroke-width="2.5" />
          <line x1="10" y1="34" x2="70" y2="34" stroke-width="2.5" />
        </svg>
      </div>
    {% endif %}

    {# Tipo evento — badge in basso #}
    <div class="absolute bottom-3 left-3 z-10">
      <span
        class="inline-flex items-center rounded-full border border-white/30 bg-white/20 px-2.5 py-1 text-xs font-bold tracking-wider text-white uppercase backdrop-blur-sm"
      >
        {{ has_type ? node.field_event_type.entity.label : 'Evento' }}
      </span>
    </div>
  </a>

  {# ── Corpo — destra ────────────────────────────────────────────── #}
  <div class="flex flex-1 flex-col gap-3 p-5">
    {# Data e ora #}
    {% if has_date %}
      <div class="flex flex-wrap items-center gap-2 text-xs font-medium text-primary">
        <svg
          class="h-3.5 w-3.5 shrink-0"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"
          aria-hidden="true"
        >
          <rect x="3" y="4" width="18" height="18" rx="2" />
          <line x1="16" y1="2" x2="16" y2="6" />
          <line x1="8" y1="2" x2="8" y2="6" />
          <line x1="3" y1="10" x2="21" y2="10" />
        </svg>
        <time datetime="{{ node.field_event_date.value|date('Y-m-d H:i') }}">{{ node.field_event_date.value|date('d/m/Y - H:i') }}</time>
        {% if has_date_end %}
          <span class="text-foreground/30">—</span>
          <time datetime="{{ node.field_event_date_end.value|date('Y-m-d H:i') }}">{{ node.field_event_date_end.value|date('d/m/Y - H:i') }}</time>
        {% endif %}
      </div>
    {% endif %}

    {# Titolo #}
    <h3 class="text-lg leading-snug font-bold tracking-tight">
      <a href="{{ url }}" class="transition-colors duration-200 hover:text-primary">{{ label }}</a>
    </h3>

    {# Località #}
    {% if has_location %}
      <div class="flex items-center gap-1.5 text-sm text-foreground/60">
        <svg
          class="h-3.5 w-3.5 shrink-0 text-foreground/40"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"
          aria-hidden="true"
        >
          <path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z" />
          <circle cx="12" cy="10" r="3" />
        </svg>
        <span>{{ node.field_event_localtion.value }}</span>
      </div>
    {% endif %}

    {# CTA #}
    <div class="mt-auto flex items-center justify-end border-t border-foreground/8 pt-3">
      {{
        include(
          'mercury:button',
          {
            variant: 'primary-inverted',
            size: 'small',
            label: 'Partecipa',
            href: url,
            icon: 'arrow-right'
          },
          with_context: false
        )
      }}
    </div>
  </div>
</article>
