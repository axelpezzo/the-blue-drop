{#
/**
 * Template full view mode — Event.
 * Struttura: hero small → breadcrumb → tre colonne (body-1 | body-2 | sidebar).
 *   body-1 (flex-1):    immagine principale + contenuto/descrizione
 *   body-2 (w-80):      scheda dettagli (data, orario, luogo, tipo)
 *   sidebar (w-64):     altri eventi — drupal_view('events', 'block_3')
 */
#}

{% set has_date = node.field_event_date.value is not empty %}
{% set has_date_end = node.field_event_date_end.value is not empty %}
{% set has_location = node.field_event_localtion.value is not empty %}
{% set has_image = content.field_event_image|render|striptags|trim is not empty %}
{% set has_type = node.field_event_type.entity is not empty %}

{# Data inizio formattata per la descrizione nell'hero #}
{% set hero_date = has_date ? node.field_event_date.value|date('d/m/Y - H:i') : '' %}
{% set hero_date_end = has_date_end ? node.field_event_date_end.value|date('d/m/Y - H:i') : '' %}

{# ── Hero ─────────────────────────────────────────────────────────── #}
{{
  include(
    'mercury:hero',
    {
      variant: 'small',
      background_color: 'foreground',
      text_color: 'light',
      content_align: 'left',
      heading_level: 1,
      heading_text: label
    },
    with_context: false
  )
}}

{# ── Breadcrumb ────────────────────────────────────────────────────── #}
{% if page_breadcrumb is not empty %}
  <div class="container mx-auto px-4 py-3">
    {{ page_breadcrumb }}
  </div>
{% endif %}

{# ── Layout: body-1 | body-2 | sidebar ───────────────────────────── #}
<div class="container mx-auto px-4 py-12 md:py-16">
  <div class="flex flex-col gap-10 lg:flex-row lg:items-start lg:gap-10">
    {# ── Body 1 — immagine + contenuto ───────────────────────────── #}
    <div class="min-w-0 flex-1">
      {# Immagine principale #}
      {% if has_image %}
        <div class="mb-8 w-full overflow-hidden [&_img]:w-full">
          {{ content.field_event_image }}
        </div>
      {% endif %}

      {# Contenuto / descrizione dell'evento #}
      <div class="prose-content flex flex-col gap-8">
        {{ content|without('field_event_image', 'field_event_date', 'field_event_date_end', 'field_event_localtion', 'field_event_type') }}
      </div>
    </div>

    {# ── Body 2 — scheda dettagli ─────────────────────────────────── #}
    <div class="w-full shrink-0 lg:w-80">
      <div class="flex flex-col gap-4 bg-card p-6 lg:sticky lg:top-8">
        <p class="text-xs font-bold tracking-widest text-foreground/40 uppercase">
          Dettagli evento
        </p>

        {# Tipo evento #}
        {% if has_type %}
          <div class="flex items-center gap-3">
            <span class="flex h-8 w-8 shrink-0 items-center justify-center rounded-full bg-primary/10 text-primary">
              <svg
                class="h-4 w-4"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="2"
                stroke-linecap="round"
                stroke-linejoin="round"
                aria-hidden="true"
              >
                <path d="M4 6h16M4 10h16M4 14h10" />
              </svg>
            </span>
            <div class="flex flex-col">
              <span class="text-xs text-foreground/40">Tipo</span>
              <span class="text-sm font-semibold">{{ node.field_event_type.entity.label }}</span>
            </div>
          </div>
        {% endif %}

        {# Data e ora inizio #}
        {% if has_date %}
          <div class="flex items-center gap-3 border-t border-foreground/8 pt-4">
            <span class="flex h-8 w-8 shrink-0 items-center justify-center rounded-full bg-primary/10 text-primary">
              <svg
                class="h-4 w-4"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="2"
                stroke-linecap="round"
                stroke-linejoin="round"
                aria-hidden="true"
              >
                <rect x="3" y="4" width="18" height="18" rx="2" />
                <line x1="16" y1="2" x2="16" y2="6" />
                <line x1="8" y1="2" x2="8" y2="6" />
                <line x1="3" y1="10" x2="21" y2="10" />
              </svg>
            </span>
            <div class="flex flex-col">
              <span class="text-xs text-foreground/40">Inizio</span>
              <time class="text-sm font-semibold" datetime="{{ node.field_event_date.value|date('Y-m-d H:i') }}">
                {{ node.field_event_date.value|date('d/m/Y - H:i') }}
              </time>
            </div>
          </div>
        {% endif %}

        {# Data e ora fine #}
        {% if has_date_end %}
          <div class="flex items-center gap-3">
            <span class="flex h-8 w-8 shrink-0 items-center justify-center rounded-full bg-primary/10 text-primary">
              <svg
                class="h-4 w-4"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="2"
                stroke-linecap="round"
                stroke-linejoin="round"
                aria-hidden="true"
              >
                <circle cx="12" cy="12" r="10" />
                <polyline points="12 6 12 12 16 14" />
              </svg>
            </span>
            <div class="flex flex-col">
              <span class="text-xs text-foreground/40">Fine</span>
              <time class="text-sm font-semibold" datetime="{{ node.field_event_date_end.value|date('Y-m-d H:i') }}">
                {{ node.field_event_date_end.value|date('d/m/Y - H:i') }}
              </time>
            </div>
          </div>
        {% endif %}

        {# Luogo #}
        {% if has_location %}
          <div class="flex items-center gap-3 border-t border-foreground/8 pt-4">
            <span class="flex h-8 w-8 shrink-0 items-center justify-center rounded-full bg-primary/10 text-primary">
              <svg
                class="h-4 w-4"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="2"
                stroke-linecap="round"
                stroke-linejoin="round"
                aria-hidden="true"
              >
                <path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z" />
                <circle cx="12" cy="10" r="3" />
              </svg>
            </span>
            <div class="flex flex-col">
              <span class="text-xs text-foreground/40">Luogo</span>
              <span class="text-sm font-semibold">{{ node.field_event_localtion.value }}</span>
            </div>
          </div>
        {% endif %}

        {# CTA partecipa #}
        <div class="border-t border-foreground/8 pt-4">
          {{
            include(
              'mercury:button',
              {
                variant: 'primary',
                size: 'medium',
                label: 'Partecipa',
                href: url,
                icon: 'arrow-right'
              },
              with_context: false
            )
          }}
        </div>
      </div>
    </div>

    {# ── Sidebar — altri eventi ────────────────────────────────────── #}
    <aside class="w-full shrink-0 lg:w-64">
      <div class="lg:sticky lg:top-8">
        <p class="mb-3 pt-6 text-xs font-bold tracking-widest text-foreground/40 uppercase">
          Altri eventi
        </p>
        {{ drupal_view('events', 'block_3') }}
      </div>
    </aside>
  </div>
</div>

{# ── Dal blog — articoli correlati ────────────────────────────────── #}
<div class="border-t border-foreground/8">
  {{ drupal_view('blog', 'block_2') }}
</div>
